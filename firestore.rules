rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: history
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - UID of the owner
    //   - title: string (required) - Short title
    //   - input: string (required) - Original input script
    //   - result: string (required) - Generated storyboard markdown
    //   - timestamp: number (required) - Creation time in ms
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidHistoryItem(data) {
      return data.keys().hasAll(['userId', 'title', 'input', 'result', 'timestamp']) &&
             data.userId is string &&
             data.title is string && data.title.size() <= 100 &&
             data.input is string && data.input.size() <= 5000 &&
             data.result is string && data.result.size() <= 20000 &&
             data.timestamp is number;
    }

    match /history/{historyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidHistoryItem(request.resource.data);
      allow update: if false; // History items are immutable for security
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
